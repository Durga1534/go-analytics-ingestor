# Redis Configuration
# For Upstash: https://upstash.com/
# Format: redis://username:password@hostname:port/db
REDIS_URL=redis://default:password@redis-hostname:6379/0

# PostgreSQL Configuration
# Format: postgres://username:password@hostname:port/database?sslmode=disable
DATABASE_URL=postgres://analytics:password@localhost:5432/analytics_db?sslmode=disable

# Server Port
PORT=8080

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# Environment (development, staging, production)
ENVIRONMENT=development
